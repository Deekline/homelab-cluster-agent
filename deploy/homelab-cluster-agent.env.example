# Copy to /etc/homelab-cluster-agent.env (chmod 600, root-owned) and fill in.

# Shared secret Home Assistant must send as the X-Agent-Token header.
AGENT_TOKEN=changeme

LISTEN_ADDR=:9090
STARTUP_SCRIPT=/opt/homelab/scripts/startup.sh
SHUTDOWN_SCRIPT=/opt/homelab/scripts/shutdown.sh

# Optional: Wake-on-LAN sent before STARTUP_SCRIPT runs. Leave WOL_MAC blank
# to disable. Target the Proxmox host's MAC (its VMs have on_boot=true).
WOL_MAC=
WOL_BROADCAST_ADDR=255.255.255.255:9
